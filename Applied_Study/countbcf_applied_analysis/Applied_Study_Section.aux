\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Gradient 2 (absolute scale).} Per-cell CATE (excess cases$/10^5$~PY) for the high-dose contrast against attained age, by sex (points are individual cells; lines are sex-specific smooths). The absolute excess rises with attained age as the baseline incidence climbs, even as the relative multiplier of Figure~\ref {fig:err-agex} fades; the male smooth sits above the female throughout.}}{6}{figure.caption.5}\protected@file@percent }
\newlabel{fig:ear-age}{{3}{6}{\textbf {Gradient 2 (absolute scale).} Per-cell CATE (excess cases$/10^5$~PY) for the high-dose contrast against attained age, by sex (points are individual cells; lines are sex-specific smooths). The absolute excess rises with attained age as the baseline incidence climbs, even as the relative multiplier of Figure~\ref {fig:err-agex} fades; the male smooth sits above the female throughout}{figure.caption.5}{}}
