\@writefile{toc}{\contentsline {subsection}{\numberline {1.2}Average treatment effect: convergence and parametric fragility}{3}{subsection.1.2}\protected@file@percent }
\newlabel{sec:applied-ate}{{1.2}{3}{Average treatment effect: convergence and parametric fragility}{subsection.1.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces ATE convergence: CountBCF (NB) versus an adjusted NB GLM. Marginal excess rate (cases$/10^5$~PY) and rate ratio with $95\%$ intervals. The two methods track each other on every contrast; CountBCF is mildly conservative. The final column gives the E-value for the point estimate and for the confidence limit nearest the null: the minimum strength of association (on the risk-ratio scale) that an unmeasured confounder would need with \emph  {both} dose and incidence to explain the contrast away.}}{4}{table.caption.2}\protected@file@percent }
\newlabel{tab:applied-ate}{{2}{4}{ATE convergence: CountBCF (NB) versus an adjusted NB GLM. Marginal excess rate (cases$/10^5$~PY) and rate ratio with $95\%$ intervals. The two methods track each other on every contrast; CountBCF is mildly conservative. The final column gives the E-value for the point estimate and for the confidence limit nearest the null: the minimum strength of association (on the risk-ratio scale) that an unmeasured confounder would need with \emph {both} dose and incidence to explain the contrast away}{table.caption.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces ATE convergence on the absolute scale: CountBCF (NB) versus the adjusted NB GLM, marginal excess rate (cases$/10^5$~PY) with $95\%$ intervals, for all four endpoint $\times $ dose-level contrasts. The two estimators are nearly coincident on every contrast, with CountBCF positioned a touch toward the null --- the expected signature of BCF's regularization. The moderate-dose stomach contrast straddles zero for both methods.}}{4}{figure.caption.3}\protected@file@percent }
\newlabel{fig:ate-conv}{{1}{4}{ATE convergence on the absolute scale: CountBCF (NB) versus the adjusted NB GLM, marginal excess rate (cases$/10^5$~PY) with $95\%$ intervals, for all four endpoint $\times $ dose-level contrasts. The two estimators are nearly coincident on every contrast, with CountBCF positioned a touch toward the null --- the expected signature of BCF's regularization. The moderate-dose stomach contrast straddles zero for both methods}{figure.caption.3}{}}
