library(stats) # For dnorm, pnorm, rnorm, runif, rbinom, etc.
g <- function(x) {
ifelse(x == 1, 2,
ifelse(x == 2, -1,
ifelse(x == 3, -4, NA))) # NA for values not 1, 2, or 3
}
# Python's generate_x_values(n)
generate_x_values <- function(n) {
x1 <- rnorm(n, mean = 0, sd = 1)
x2 <- rnorm(n, mean = 0, sd = 1)
x3 <- rnorm(n, mean = 0, sd = 1)
x4 <- sample(c(1, 2, 3), n, replace = TRUE) # np.random.choice
x5 <- sample(c(0, 1), n, replace = TRUE)    # np.random.randint(0, 2, n)
return(list(x1 = x1, x2 = x2, x3 = x3, x4 = x4, x5 = x5))
}
# Python's propensity_function(mu, x1)
propensity_function <- function(mu, x1) {
u_i <- runif(length(mu), min = 0, max = 1)
s <- sd(mu) # np.std in Python
# Note: pnorm is R's equivalent of scipy.stats.norm.cdf
pi <- 0.8 * pnorm((3 * mu) / s - 0.5 * x1) + 0.05 + u_i / 10
return(pi)
}
# Python's assign_treatment(pi)
assign_treatment <- function(pi) {
# np.random.binomial(1, pi) is equivalent to rbinom(n, size=1, prob=pi)
return(rbinom(length(pi), size = 1, prob = pi))
}
# Python's simulate_heterogeneous_nonlinear(n)
simulate_heterogeneous_nonlinear <- function(n) {
set.seed(n)
x_values <- generate_x_values(n)
x1 <- x_values$x1
x2 <- x_values$x2
x3 <- x_values$x3
x4 <- x_values$x4
x5 <- x_values$x5
mu <- -6 + g(x4) + 6 * abs(x3 - 1) # Non-linear baseline outcome
tau <- 1 + 2 * x2 * x5            # Heterogeneous treatment effect
pi <- propensity_function(mu, x1)
pi[pi < 0.001] <- 0.001
pi[pi > 0.999] <- 0.999
treatment <- assign_treatment(pi)
outcome <- mu + treatment * tau
data.frame(
x1 = x1, x2 = x2, x3 = x3, x4 = x4, x5 = x5,
z = treatment,
y = outcome,
tau = tau,
mu = mu,
pi = pi
)
}
data <- simulate_heterogeneous_nonlinear(250)
