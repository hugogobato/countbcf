set.seed(123) # For reproducibility
n_obs <- 250 # Number of observations
beta_X1 <- 0.5 # For continuous covariate
beta_X2 <- -0.8 # For binary covariate
beta_X3_level2 <- 0.6 # For categorical covariate (level 2 vs. level 1 baseline)
beta_X3_level3 <- -0.4 # For categorical covariate (level 3 vs. level 1 baseline)
intercept_zi <- -1.5 # Baseline log-odds of being a structural zero
beta_zi_X1 <- 0.7  # X1 increases likelihood of structural zero
beta_zi_X2 <- -0.5 # X2 decreases likelihood of structural zero
intercept_nb <- 1.5 # Baseline log-mean of the count
beta_nb_X1 <- 0.3  # X1 increases mean count
beta_nb_X2 <- 0.4  # X2 increases mean count
beta_nb_X3_level2 <- 0.8 # X3 level 2 increases mean count
beta_nb_X3_level3 <- -0.2 # X3 level 3 decreases mean count
nb_dispersion_size <- 2 # Also called 'k' or 'theta'. Set > 0.
# Smaller values mean more overdispersion.
# --- 2. Generate Covariates ---
X1 <- rnorm(n_obs, mean = 0, sd = 1) # Continuous
X2 <- rbinom(n_obs, size = 1, prob = 0.5) # Binary (0 or 1)
X3 <- sample(c("A", "B", "C"), n_obs, replace = TRUE, prob = c(0.4, 0.3, 0.3)) # Categorical
# Convert categorical to dummy variables for linear predictors
# (A is baseline, B and C are indicator variables)
X3_B <- as.numeric(X3 == "B")
X3_C <- as.numeric(X3 == "C")
linear_predictor_zi <- intercept_zi + beta_zi_X1 * X1 + beta_zi_X2 * X2
prob_structural_zero <- 1 / (1 + exp(-linear_predictor_zi))
# Decide if an observation is a structural zero
is_structural_zero <- rbinom(n_obs, size = 1, prob = prob_structural_zero)
linear_predictor_nb <- intercept_nb + beta_nb_X1 * X1 + beta_nb_X2 * X2 +
beta_nb_X3_level2 * X3_B + beta_nb_X3_level3 * X3_C
mu_nb <- exp(linear_predictor_nb)
nb_counts <- rnbinom(n_obs, size = nb_dispersion_size, mu = mu_nb)
Y_zinb <- ifelse(is_structural_zero == 1, 0, nb_counts)
dgp_data_zinb <- tibble(
X1 = X1,
X2 = X2,
X3 = factor(X3, levels = c("A", "B", "C")), # Ensure X3 is a factor with correct levels
is_structural_zero = is_structural_zero, # For debugging/understanding DGP
prob_structural_zero = prob_structural_zero, # For debugging/understanding DGP
mu_nb_true = mu_nb, # True mean for NB part (if not structural zero)
Y_zinb = Y_zinb
)
print(summary(dgp_data_zinb))
hist(dgp_data_zinb$Y_zinb, breaks = 0:max(dgp_data_zinb$Y_zinb + 1), main = "Distribution of ZINB Counts", xlab = "Count")
